<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DreamLauncher.Avalonia.Dialogs.AccountSwitchWindow"
        Width="620"
        Height="470"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent">
  <Border Margin="10" Padding="24" CornerRadius="22" Background="#20243D" BorderBrush="#5C6683" BorderThickness="1">
    <Grid RowDefinitions="Auto,*,Auto">
      <StackPanel>
        <TextBlock Text="切换账号" FontSize="26" FontWeight="Bold" Foreground="White" />
        <TextBlock Text="选择一个已登录账号作为当前启动账号。" Foreground="#C7CBE0" Margin="0,8,0,0" />
      </StackPanel>
      <ListBox x:Name="AccountsListBox" Grid.Row="1" Margin="0,20,0,18" Background="#303A57" BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border CornerRadius="14" Padding="14" Margin="0,0,0,10" Background="#321746" BorderBrush="#8640FF" BorderThickness="1">
              <Grid ColumnDefinitions="58,*,Auto">
                <Border Width="46" Height="46" CornerRadius="16" Background="#FF5BAB">
                  <TextBlock Text="账" FontWeight="Bold" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0">
                  <TextBlock Text="{Binding PlayerName}" Foreground="White" FontWeight="Bold" FontSize="16" />
                  <TextBlock Text="{Binding Uuid}" Foreground="#C7CBE0" FontSize="12" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="#FF5BAB" VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
        <Button Content="删除账号" MinWidth="110" Click="Delete_Click" />
        <Button Content="切换" MinWidth="92" Background="#FF5BAB" Foreground="White" Click="Switch_Click" />
        <Button Content="取消" MinWidth="92" Click="Cancel_Click" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
