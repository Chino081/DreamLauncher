<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DreamLauncher.Avalonia.MainWindow"
        Title="Dreamtc Tamrac Launcher"
        Icon="Assets/favicon.ico"
        Width="1180"
        Height="760"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">
  <Window.Resources>
    <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#182334" Offset="0" />
      <GradientStop Color="#20243D" Offset="0.52" />
      <GradientStop Color="#241D45" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="TextPrimary" Color="#F4F7FB" />
    <SolidColorBrush x:Key="TextMuted" Color="#C8D0E2" />
    <SolidColorBrush x:Key="Panel" Color="#2D334A" />
    <SolidColorBrush x:Key="PanelAlt" Color="#353B52" />
    <SolidColorBrush x:Key="Glass" Color="#3A4059" Opacity="0.64" />
    <SolidColorBrush x:Key="GlassLight" Color="#555B72" Opacity="0.48" />
    <SolidColorBrush x:Key="Stroke" Color="#4B5269" />
    <SolidColorBrush x:Key="StrokeSoft" Color="#626A80" />
    <SolidColorBrush x:Key="Accent" Color="#FF5BA7" />
    <SolidColorBrush x:Key="AccentBlue" Color="#7D46EF" />
    <SolidColorBrush x:Key="PurpleLine" Color="#7D35E8" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style Selector="Button">
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="18,0" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="Background" Value="{StaticResource PanelAlt}" />
      <Setter Property="BorderBrush" Value="#46506A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource Accent}" />
      <Setter Property="BorderBrush" Value="#FF7FC0" />
    </Style>

    <Style Selector="Button.purple">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource AccentBlue}" />
      <Setter Property="BorderBrush" Value="#B58BFF" />
    </Style>

    <Style Selector="Button.window">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="Background" Value="#44506A" />
      <Setter Property="BorderBrush" Value="#59647C" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style Selector="Button.close">
      <Setter Property="Background" Value="#C2185B" />
      <Setter Property="BorderBrush" Value="#FF6BAF" />
    </Style>

    <Style Selector="Button.nav">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#B8B2D8" />
      <Setter Property="MinHeight" Value="48" />
      <Setter Property="Width" Value="92" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="FontSize" Value="15" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="Background" Value="#222838" />
      <Setter Property="BorderBrush" Value="#A9B0C2" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="Background" Value="{StaticResource PanelAlt}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="ComboBoxItem">
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="Padding" Value="12,9" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="#202638" />
    </Style>

    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="Transparent" Padding="{TemplateBinding Padding}">
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="ProgressBar">
      <Setter Property="Height" Value="8" />
      <Setter Property="MinHeight" Value="8" />
      <Setter Property="Background" Value="#2B3146" />
      <Setter Property="BorderBrush" Value="#596176" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Foreground">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#FF5BA7" Offset="0" />
          <GradientStop Color="#8A45FF" Offset="1" />
        </LinearGradientBrush>
      </Setter>
    </Style>
  </Window.Styles>

  <Border CornerRadius="22"
          Background="{StaticResource ShellBrush}"
          BorderBrush="#2E3850"
          BorderThickness="1"
          ClipToBounds="True">
    <Grid>
      <Ellipse Width="430" Height="430" Fill="#7C4576" Opacity="0.20"
               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-170,-170,0,0" />
      <Ellipse Width="330" Height="330" Fill="#6E5BB8" Opacity="0.18"
               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-90,-70,0" />
      <Ellipse Width="300" Height="300" Fill="#9F4C87" Opacity="0.20"
               HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-70,-95" />

      <Grid RowDefinitions="76,*">
        <Grid Background="Transparent" ColumnDefinitions="*,Auto" PointerPressed="TitleBar_PointerPressed">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
            <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource Accent}">
              <TextBlock Text="梦" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
              <TextBlock Text="Dreamtc Tamrac Launcher" FontSize="20" FontWeight="Bold" />
              <TextBlock Text="甜酷二次元风 · Minecraft Launcher · Avalonia版" FontSize="12" Foreground="{StaticResource TextMuted}" />
            </StackPanel>
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="0,0,20,0">
            <Button Classes="window" Content="－" Click="Minimize_Click" />
            <Button Classes="window close" Content="×" Click="Close_Click" />
          </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="18"
                Background="{StaticResource Panel}"
                BorderBrush="#434A63"
                BorderThickness="1"
                CornerRadius="20"
                Padding="18">
          <Grid RowDefinitions="58,*">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
              <Button x:Name="LaunchNavButton" Classes="nav" Content="✦ 启动" Click="LaunchNav_Click" />
              <Button x:Name="DownloadNavButton" Classes="nav" Content="⬇ 下载" Click="DownloadNav_Click" Margin="12,0,0,0" />
              <Button x:Name="ContentNavButton" Classes="nav" Content="◇ 资源" Click="ContentNav_Click" Margin="12,0,0,0" />
              <Button x:Name="SettingsNavButton" Classes="nav" Content="⚙ 设置" Click="SettingsNav_Click" Margin="12,0,0,0" />
            </StackPanel>

            <Grid Grid.Row="1">
              <Grid x:Name="LaunchPage" RowDefinitions="96,*">
                <Border Background="{StaticResource Glass}"
                        BorderBrush="{StaticResource Stroke}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="18,14"
                        Margin="0,0,0,14"
                        PointerPressed="TitleBar_PointerPressed">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="开始游戏" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="在这里选择版本、查看版本信息，然后直接启动游戏。"
                               FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="*,300" ColumnSpacing="14">
                  <Border Background="{StaticResource Glass}"
                          BorderBrush="{StaticResource Stroke}"
                          BorderThickness="1"
                          CornerRadius="20"
                          Padding="18">
                    <Grid RowDefinitions="Auto,*">
                      <Grid>
                        <TextBlock Text="版本列表" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                        <Border HorizontalAlignment="Right"
                                Background="#43206F"
                                BorderBrush="#8A45FF"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="10,4">
                          <TextBlock Text="推荐优先" FontSize="12" />
                        </Border>
                      </Grid>

                      <Border Grid.Row="1"
                              Background="{StaticResource GlassLight}"
                              BorderBrush="{StaticResource StrokeSoft}"
                              BorderThickness="1"
                              CornerRadius="18"
                              ClipToBounds="True"
                              Padding="12"
                              Margin="0,16,0,0">
                        <ListBox ItemsSource="{Binding Clients}"
                                 SelectedItem="{Binding SelectedClient}"
                                 Foreground="{StaticResource TextPrimary}">
                          <ListBox.ItemTemplate>
                            <DataTemplate>
                              <Border Background="{Binding LaunchCardBackground}"
                                      BorderBrush="{Binding LaunchCardBorderBrush}"
                                      BorderThickness="1"
                                      CornerRadius="14"
                                      ClipToBounds="True"
                                      Padding="14"
                                      MinHeight="64">
                                <Grid ColumnDefinitions="26,*">
                                  <Border Width="6"
                                          CornerRadius="3"
                                          Background="#FFE7F3"
                                          Opacity="{Binding SelectedMarkerOpacity}"
                                          HorizontalAlignment="Left" />
                                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" />
                                    <TextBlock Text="{Binding LoaderText}" FontSize="12" Foreground="#F5D2E8" Margin="0,5,0,0" />
                                  </StackPanel>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </Border>
                    </Grid>
                  </Border>

                  <Grid Grid.Column="1" RowDefinitions="222,*" RowSpacing="14">
                    <Border Background="{StaticResource Glass}"
                            BorderBrush="{StaticResource PurpleLine}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="17"
                            Margin="0,1,0,1">
                      <Grid RowDefinitions="Auto,112,Auto">
                        <TextBlock Text="账号管理" FontSize="18" FontWeight="Bold" />
                        <Border Grid.Row="1"
                                Background="#2B173F"
                                BorderBrush="{StaticResource PurpleLine}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="10"
                                Margin="0,12,0,8">
                          <Grid ColumnDefinitions="58,*">
                            <Border Width="58" Height="58" CornerRadius="17" Background="{StaticResource Accent}" VerticalAlignment="Center" ClipToBounds="True">
                              <Grid>
                                <TextBlock Text="{Binding CurrentAccountInitial}" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Image Source="{Binding CurrentAccountAvatar}"
                                       Stretch="UniformToFill"
                                       IsVisible="{Binding HasCurrentAccountAvatar}" />
                              </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                              <TextBlock Text="{Binding CurrentAccountName}" FontSize="17" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                              <TextBlock Text="{Binding CurrentAccountStatusText}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                              <TextBlock Text="{Binding CurrentAccountOnlineText}" FontSize="12" Foreground="{StaticResource Accent}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                          </Grid>
                        </Border>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Spacing="10">
                          <Button Classes="primary" Content="登录账号" Click="LoginAccount_Click" />
                          <Button Content="切换账号" Click="SwitchAccount_Click" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource Glass}"
                            BorderBrush="{StaticResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="18">
                      <Grid>
                        <Ellipse Width="230" Height="230" Fill="#9F4C87" Opacity="0.16"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-95,-105" />
                        <StackPanel>
                          <TextBlock Text="启动面板" FontSize="13" Foreground="#DAB7FF" />
                          <Button Classes="primary"
                                  Content="{Binding SelectedClient.PrimaryActionText}"
                                  Command="{Binding PrimaryActionCommand}"
                                  MinHeight="66"
                                  FontSize="20"
                                  Margin="0,12,0,0" />
                          <Button Content="打开版本详情"
                                  Click="DownloadNav_Click"
                                  Margin="0,14,0,0"
                                  HorizontalAlignment="Left" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </Grid>
                </Grid>
              </Grid>

              <Grid x:Name="DownloadPage" RowDefinitions="96,*" IsVisible="False">
                <Border Background="{StaticResource Glass}"
                        BorderBrush="{StaticResource Stroke}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="18,14"
                        Margin="0,0,0,14"
                        PointerPressed="TitleBar_PointerPressed">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="下载中心" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="展示可用客户端列表和当前下载进度。"
                               FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="*,320" ColumnSpacing="14">
                  <Border Background="{StaticResource Glass}"
                          BorderBrush="{StaticResource Stroke}"
                          BorderThickness="1"
                          CornerRadius="20"
                          Padding="18">
                    <Grid RowDefinitions="Auto,*">
                      <TextBlock Text="客户端列表" FontSize="20" FontWeight="Bold" />
                      <Border Grid.Row="1"
                              Background="{StaticResource GlassLight}"
                              BorderBrush="{StaticResource StrokeSoft}"
                              BorderThickness="1"
                              CornerRadius="18"
                              ClipToBounds="True"
                              Padding="12"
                              Margin="0,16,0,0">
                        <ListBox ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}">
                          <ListBox.ItemTemplate>
                            <DataTemplate>
                              <Border Background="#555B72"
                                      BorderBrush="#626A80"
                                      BorderThickness="1"
                                      CornerRadius="14"
                                      ClipToBounds="True"
                                      Padding="16"
                                      MinHeight="82">
                                <Grid ColumnDefinitions="*,168">
                                  <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" />
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,5,0,0" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LoaderText}" FontSize="12" Foreground="#FFFFFF" Margin="0,8,0,0" />
                                  </StackPanel>
                                  <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Classes="purple"
                                            Content="{Binding DownloadCenterBadgeText}"
                                            Click="DownloadClientAction_Click"
                                            IsVisible="{Binding CanDownloadFromDownloadCenter}"
                                            MinWidth="112"
                                            Height="38" />
                                    <Border Background="#243649"
                                            BorderBrush="#2ED47A"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="18,0"
                                            Height="38"
                                            MinWidth="112"
                                            IsVisible="{Binding IsDownloadCenterBadgeVisible}">
                                      <TextBlock Text="{Binding DownloadCenterBadgeText}"
                                                 FontSize="14"
                                                 FontWeight="Bold"
                                                 Foreground="#2ED47A"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                    </Border>
                                  </Grid>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>
                      </Border>
                    </Grid>
                  </Border>

                  <Grid Grid.Column="1" RowDefinitions="220,*" RowSpacing="14">
                    <Border Background="{StaticResource Glass}"
                            BorderBrush="{StaticResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="18">
                      <StackPanel>
                        <TextBlock Text="当前下载" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedClient.Name}" FontSize="16" FontWeight="Bold" Margin="0,16,0,0" />
                        <TextBlock Text="游戏版本：" Foreground="{StaticResource TextMuted}" Margin="0,16,0,0" />
                        <TextBlock Text="{Binding SelectedClient.Version}" Foreground="#FFFFFF" Margin="74,-19,0,0" />
                        <TextBlock Text="客户端版本：" Foreground="{StaticResource TextMuted}" Margin="0,12,0,0" />
                        <TextBlock Text="{Binding SelectedClient.LoaderText}" Foreground="#FFFFFF" Margin="86,-19,0,0" />
                        <TextBlock Text="{Binding CurrentDownloadStatusText}" Foreground="{StaticResource Accent}" TextWrapping="Wrap" Margin="0,12,0,0" />
                      </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource Glass}"
                            BorderBrush="{StaticResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="18">
                      <Grid>
                        <Ellipse Width="230" Height="230" Fill="#9F4C87" Opacity="0.16"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-95,-105" />
                        <StackPanel>
                          <TextBlock Text="下载统计" FontSize="18" FontWeight="Bold" />
                          <Border Background="{StaticResource GlassLight}" CornerRadius="14" Padding="14" Margin="0,14,0,0">
                            <TextBlock Text="{Binding ProgressText}" FontWeight="Bold" TextWrapping="Wrap" />
                          </Border>
                          <Border Background="{StaticResource GlassLight}" CornerRadius="14" Padding="14" Margin="0,12,0,0">
                            <TextBlock Text="{Binding OperationText}" TextWrapping="Wrap" />
                          </Border>
                          <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Margin="0,14,0,0" />
                        </StackPanel>
                      </Grid>
                    </Border>
                  </Grid>
                </Grid>
              </Grid>

              <Grid x:Name="ContentPage" RowDefinitions="96,*" IsVisible="False">
                <Border Background="{StaticResource Glass}"
                        BorderBrush="{StaticResource Stroke}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="18,14"
                        Margin="0,0,0,14"
                        PointerPressed="TitleBar_PointerPressed">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="资源管理" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="{Binding ContentStatusMessage}"
                               FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="190,*" ColumnSpacing="14">
                  <Border Background="{StaticResource Glass}"
                          BorderBrush="{StaticResource Stroke}"
                          BorderThickness="1"
                          CornerRadius="20"
                          Padding="14">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <StackPanel>
                        <TextBlock Text="游戏资源"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   Margin="2,0,0,10" />
                        <Button x:Name="ModSubNavButton"
                                Content="{Binding ModsTabText}"
                                Classes="nav"
                                Width="162"
                                MinHeight="48"
                                Padding="14,0"
                                HorizontalContentAlignment="Left"
                                Click="ModSubNav_Click"
                                Margin="0,0,0,8" />
                        <Button x:Name="ResourcePackSubNavButton"
                                Content="{Binding ResourcePacksTabText}"
                                Classes="nav"
                                Width="162"
                                MinHeight="48"
                                Padding="14,0"
                                HorizontalContentAlignment="Left"
                                Click="ResourcePackSubNav_Click"
                                Margin="0,0,0,8" />
                        <Button x:Name="ShaderPackSubNavButton"
                                Content="{Binding ShaderPacksTabText}"
                                Classes="nav"
                                Width="162"
                                MinHeight="48"
                                Padding="14,0"
                                HorizontalContentAlignment="Left"
                                Click="ShaderPackSubNav_Click" />
                      </StackPanel>

                      <StackPanel Grid.Row="2">
                        <Border Height="1" Background="#596176" Margin="0,18,0,14" />
                        <TextBlock Text="{Binding ContentGameDirectory}"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </Border>

                  <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="14">
                    <Border Background="{StaticResource Glass}"
                            BorderBrush="{StaticResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="14"
                            MinHeight="74">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="ContentSubTitleTextBlock"
                                   Text="Mod"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                          <Button Content="打开文件夹"
                                  Width="118"
                                  Height="42"
                                  Padding="0"
                                  Click="OpenContentFolder_Click" />
                          <Button Content="从文件安装"
                                  Width="126"
                                  Height="42"
                                  Padding="0"
                                  Click="InstallContentFromFile_Click" />
                          <Button Content="刷新"
                                  Width="86"
                                  Height="42"
                                  Padding="0"
                                  Click="RefreshContent_Click" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <Border x:Name="ModContentPanel"
                            Grid.Row="1"
                            Background="{StaticResource Glass}"
                            BorderBrush="{StaticResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="16"
                            DragDrop.AllowDrop="True"
                            DragDrop.DragOver="ContentDropZone_DragOver"
                            DragDrop.Drop="ModDrop_Drop">
                      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Mods}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="#4A5065"
                                      BorderBrush="{Binding StatusBrush}"
                                      BorderThickness="1"
                                      CornerRadius="14"
                                      Padding="12"
                                      MinHeight="86"
                                      Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,90">
                                  <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding DetailText}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,5,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="12"
                                               Foreground="{Binding StatusBrush}"
                                               Margin="0,5,0,0" />
                                  </StackPanel>
                                  <Button Grid.Column="1"
                                          Content="{Binding ActionText}"
                                          Width="78"
                                          Height="42"
                                          Padding="0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Click="ToggleContentItem_Click" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Border>

                    <Border x:Name="ResourcePackContentPanel"
                            Grid.Row="1"
                            Background="{StaticResource Glass}"
                            BorderBrush="{StaticResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="16"
                            IsVisible="False"
                            DragDrop.AllowDrop="True"
                            DragDrop.DragOver="ContentDropZone_DragOver"
                            DragDrop.Drop="ResourcePackDrop_Drop">
                      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ResourcePacks}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="#4A5065"
                                      BorderBrush="{Binding StatusBrush}"
                                      BorderThickness="1"
                                      CornerRadius="14"
                                      Padding="12"
                                      MinHeight="86"
                                      Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,90">
                                  <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding DetailText}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,5,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="12"
                                               Foreground="{Binding StatusBrush}"
                                               Margin="0,5,0,0" />
                                  </StackPanel>
                                  <Button Grid.Column="1"
                                          Content="{Binding ActionText}"
                                          Width="78"
                                          Height="42"
                                          Padding="0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Click="ToggleContentItem_Click" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Border>

                    <Border x:Name="ShaderPackContentPanel"
                            Grid.Row="1"
                            Background="{StaticResource Glass}"
                            BorderBrush="{StaticResource Stroke}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="16"
                            IsVisible="False"
                            DragDrop.AllowDrop="True"
                            DragDrop.DragOver="ContentDropZone_DragOver"
                            DragDrop.Drop="ShaderPackDrop_Drop">
                      <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ShaderPacks}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="#4A5065"
                                      BorderBrush="{Binding StatusBrush}"
                                      BorderThickness="1"
                                      CornerRadius="14"
                                      Padding="12"
                                      MinHeight="86"
                                      Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,90">
                                  <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding DetailText}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,5,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="12"
                                               Foreground="{Binding StatusBrush}"
                                               Margin="0,5,0,0" />
                                  </StackPanel>
                                  <Button Grid.Column="1"
                                          Content="{Binding ActionText}"
                                          Width="78"
                                          Height="42"
                                          Padding="0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Click="ToggleContentItem_Click" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </ScrollViewer>
                    </Border>
                  </Grid>
                </Grid>
              </Grid>

              <Grid x:Name="SettingsPage" ColumnDefinitions="260,*" ColumnSpacing="14" IsVisible="False">
                <Border Background="{StaticResource Glass}"
                        BorderBrush="{StaticResource Stroke}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="18"
                        Margin="0,0,0,0">
                  <StackPanel HorizontalAlignment="Center">
                    <Border Width="80" Height="80" Background="{StaticResource AccentBlue}" CornerRadius="20" Margin="0,12,0,20">
                      <TextBlock Text="梦" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Dreamtc Tamrac Launcher" FontSize="16" FontWeight="Bold" TextAlignment="Center" />
                    <TextBlock Text="甜酷二次元风" Foreground="{StaticResource TextMuted}" Margin="0,6,0,20" TextAlignment="Center" />
                    <Border Height="1" Width="190" Background="#586078" Margin="0,0,0,18" />
                    <TextBlock Text="版本 v0.1.0" Foreground="#8790A8" />
                  </StackPanel>
                </Border>

                <Grid Grid.Column="1" RowDefinitions="78,*">
                  <Border Background="{StaticResource Glass}"
                          BorderBrush="{StaticResource Stroke}"
                          BorderThickness="1"
                          CornerRadius="20"
                          Padding="18,14"
                          Margin="0,0,0,14"
                          PointerPressed="TitleBar_PointerPressed">
                    <TextBlock Text="设置" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
                  </Border>

                  <Border Grid.Row="1"
                          Background="{StaticResource Glass}"
                          BorderBrush="{StaticResource Stroke}"
                          BorderThickness="1"
                          CornerRadius="20"
                          Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                      <StackPanel>
                        <TextBlock Text="Java 环境" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" />
                        <Border Background="#3A4058" CornerRadius="14" Padding="16" Margin="0,10,0,22">
                          <Grid RowDefinitions="Auto,12,Auto,8,Auto" ColumnDefinitions="*,112,96" ColumnSpacing="12">
                            <TextBlock Grid.ColumnSpan="3"
                                       Text="选择或自动检测 Java 运行环境，用于启动当前选中的 Minecraft 客户端。"
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap" />
                            <ComboBox Grid.Row="2"
                                      ItemsSource="{Binding JavaRuntimeOptions}"
                                      SelectedItem="{Binding SelectedJavaRuntimeOption}"
                                      Height="36"
                                      Padding="10,6"
                                      MaxDropDownHeight="170">
                              <ComboBox.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                              </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Row="2" Grid.Column="1" Classes="purple" Content="自动检测" Command="{Binding DetectJavaCommand}" Width="112" Height="40" />
                            <Button Grid.Row="2" Grid.Column="2" Content="添加" Click="ChooseJava_Click" Width="96" Height="40" />
                            <TextBlock Grid.Row="4"
                                       Grid.ColumnSpan="3"
                                       Text="{Binding JavaRuntimeStatusText}"
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap" />
                          </Grid>
                        </Border>

                        <TextBlock Text="最大内存" Foreground="#00C28A" FontWeight="Bold" />
                        <Border Background="#3A4058" CornerRadius="14" Padding="16" Margin="0,10,0,22">
                          <Grid RowDefinitions="Auto,12,Auto,8,Auto" ColumnDefinitions="*,128,42" ColumnSpacing="12">
                            <TextBlock Grid.ColumnSpan="3"
                                       Text="默认自动使用当前客户端建议内存，也可以选择常用档位或手动填写。"
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap" />
                            <ComboBox Grid.Row="2"
                                      ItemsSource="{Binding MemoryPresetOptions}"
                                      SelectedItem="{Binding SelectedMemoryPreset}"
                                      Height="36"
                                      Padding="10,6"
                                      MaxDropDownHeight="170">
                              <ComboBox.ItemTemplate>
                                <DataTemplate>
                                  <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                              </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Text="{Binding MemoryMbText}"
                                     Height="36"
                                     IsEnabled="{Binding IsCustomMemorySelected}"
                                     Opacity="{Binding CustomMemoryInputOpacity}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="MB" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="4"
                                       Grid.ColumnSpan="3"
                                       Text="{Binding MemoryStatusText}"
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap" />
                          </Grid>
                        </Border>

                        <TextBlock Text="下载" Foreground="{StaticResource Accent}" FontWeight="Bold" />
                        <Border Background="#3A4058" CornerRadius="14" Padding="16" Margin="0,10,0,22">
                          <Grid RowDefinitions="Auto,12,Auto" ColumnDefinitions="140,*">
                            <TextBlock Text="失败重试次数" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding RetryCountText}" />
                            <TextBlock Grid.Row="2" Text="下载限速 KB/s" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SpeedLimitText}" Watermark="留空不限速" />
                          </Grid>
                        </Border>

                        <TextBlock Text="文件校验工具" Foreground="#00C28A" FontWeight="Bold" />
                        <Border Background="#3A4058" CornerRadius="14" Padding="16" Margin="0,10,0,0">
                          <Grid RowDefinitions="Auto,12,Auto,12,Auto,12,Auto,12,Auto"
                                ColumnDefinitions="140,*,86,86"
                                ColumnSpacing="10">
                            <TextBlock Text="本地文件" VerticalAlignment="Center" />
                            <TextBox x:Name="HashToolPathTextBox" Grid.Column="1" />
                            <Button Grid.Column="2" Content="选择" Click="ChooseHashFile_Click" />
                            <Button Grid.Column="3" Classes="primary" Content="计算" Click="CalculateHash_Click" />

                            <TextBlock Grid.Row="2" Text="SHA256" VerticalAlignment="Center" />
                            <TextBox x:Name="HashToolSha256TextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" IsReadOnly="True" />

                            <TextBlock Grid.Row="4" Text="Size 字节" VerticalAlignment="Center" />
                            <TextBox x:Name="HashToolSizeTextBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" IsReadOnly="True" />

                            <TextBlock Grid.Row="6" Text="JSON 片段" VerticalAlignment="Top" Margin="0,8,0,0" />
                            <TextBox x:Name="HashToolJsonTextBox"
                                     Grid.Row="6"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="3"
                                     Height="76"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap" />

                            <Button Grid.Row="8" Grid.Column="3" Content="复制结果" Click="CopyHashResult_Click" />
                          </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,18,0,0">
                          <Button Content="重新读取" Command="{Binding RefreshCommand}" />
                          <Button Classes="primary" Content="保存设置" Command="{Binding SaveSettingsCommand}" />
                        </StackPanel>
                      </StackPanel>
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Border>
</Window>
