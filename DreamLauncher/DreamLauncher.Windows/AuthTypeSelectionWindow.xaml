<Window x:Class="DreamLauncher.Windows.AuthTypeSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择验证类型"
        Width="470"
        Height="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="{StaticResource TextPrimary}">
    <Window.Resources>
        <LinearGradientBrush x:Key="DialogShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1B2638" Offset="0" />
            <GradientStop Color="#282845" Offset="0.58" />
            <GradientStop Color="#321F4B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="AuthOptionRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="#3A4059"
                                BorderBrush="#515970"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="IconShell"
                                        Width="32"
                                        Height="32"
                                        Background="#2E344A"
                                        BorderBrush="#67708A"
                                        BorderThickness="1"
                                        CornerRadius="11"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{TemplateBinding Tag}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF65AE" />
                                <Setter TargetName="Root" Property="Background" Value="#454B61" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3E2558" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8A45FF" />
                                <Setter TargetName="IconShell" Property="Background" Value="{StaticResource Accent}" />
                                <Setter TargetName="IconShell" Property="BorderBrush" Value="#FF9DCC" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                                <Setter TargetName="Root" Property="Background" Value="#30364B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#474E63" />
                                <Setter TargetName="IconShell" Property="Background" Value="#343A4F" />
                                <Setter TargetName="IconShell" Property="BorderBrush" Value="#555C70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10"
            Background="{StaticResource DialogShellBrush}"
            BorderBrush="#48516B"
            BorderThickness="1"
            CornerRadius="22"
            ClipToBounds="True"
            MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
        <Grid>
            <Ellipse Width="220" Height="220" Fill="#7D46EF" Opacity="0.16"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-95,-80,0" />
            <Ellipse Width="190" Height="190" Fill="#FF5BA7" Opacity="0.13"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-70,0,0,-90" />

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Background="Transparent" MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="新建档案" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="选择一个账号验证类型继续登录"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,18,0,14">
                    <RadioButton x:Name="MicrosoftRadio"
                                 Content="正版验证"
                                 Tag="✓"
                                 Style="{StaticResource AuthOptionRadio}"
                                 Checked="AuthRadio_Checked" />
                    <RadioButton x:Name="ThirdPartyRadio"
                                 Content="第三方验证"
                                 Tag="3"
                                 Style="{StaticResource AuthOptionRadio}"
                                 IsEnabled="False"
                                 Checked="AuthRadio_Checked" />
                    <RadioButton x:Name="OfflineRadio"
                                 Content="离线验证"
                                 Tag="∞"
                                 Style="{StaticResource AuthOptionRadio}"
                                 IsEnabled="False"
                                 Checked="AuthRadio_Checked" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="ContinueButton"
                            Content="继续"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            Click="Continue_Click" />
                    <Button Content="取消"
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,0,0"
                            Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
