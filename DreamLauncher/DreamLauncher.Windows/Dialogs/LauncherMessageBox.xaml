<Window x:Class="DreamLauncher.Windows.Dialogs.LauncherMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DreamLauncher"
        Width="460"
        Height="230"
        MinWidth="420"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="{StaticResource TextPrimary}">
    <Window.Resources>
        <LinearGradientBrush x:Key="DialogShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1B2638" Offset="0" />
            <GradientStop Color="#282845" Offset="0.58" />
            <GradientStop Color="#321F4B" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Border Margin="10"
            Background="{StaticResource DialogShellBrush}"
            BorderBrush="#48516B"
            BorderThickness="1"
            CornerRadius="20"
            ClipToBounds="True">
        <Grid>
            <Ellipse Width="180" Height="180" Fill="#7D46EF" Opacity="0.16"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-86,-72,0" />
            <Ellipse Width="160" Height="160" Fill="#FF5BA7" Opacity="0.13"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-70,0,0,-80" />

            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Background="Transparent" MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
                    <TextBlock x:Name="TitleTextBlock"
                               Text="提示"
                               FontSize="21"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="36"
                            Height="36"
                            Background="#3E2558"
                            BorderBrush="{StaticResource AccentBlue}"
                            BorderThickness="1"
                            CornerRadius="12"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="IconTextBlock"
                                   Text="!"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <TextBlock x:Name="MessageTextBlock"
                               Grid.Column="1"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="14"
                               LineHeight="22"
                               VerticalAlignment="Center" />
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="取消"
                            Style="{StaticResource SecondaryButton}"
                            Visibility="Collapsed"
                            Click="Cancel_Click" />
                    <Button x:Name="OkButton"
                            Content="确定"
                            Style="{StaticResource PrimaryButton}"
                            Margin="10,0,0,0"
                            Click="Ok_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
