<Window x:Class="DreamLauncher.Windows.Dialogs.MicrosoftDeviceCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Microsoft 登录"
        Width="460"
        Height="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="{StaticResource TextPrimary}">
    <Border Margin="10"
            Padding="20"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource StrokeSoft}"
            BorderThickness="1"
            CornerRadius="20"
            MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Background="Transparent" MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
                <TextBlock Text="Microsoft 登录" FontSize="20" FontWeight="Bold" />
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="浏览器已打开，请在页面中输入下面的代码。代码已自动复制。"
                       Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,18" />

            <Border Grid.Row="2"
                    Background="{StaticResource PanelBackgroundAlt}"
                    BorderBrush="{StaticResource StrokeSoft}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="18">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="登录代码" Foreground="{StaticResource TextMuted}" />
                    <TextBlock x:Name="CodeTextBlock"
                               Text="--------"
                               FontSize="34"
                               FontWeight="Bold"
                               Margin="0,8,0,0" />
                    <TextBlock Text="完成网页登录后，此窗口会自动关闭。"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="重新打开网页" Style="{StaticResource SecondaryButton}" Click="OpenBrowser_Click" />
                <Button Content="复制代码" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="CopyCode_Click" />
                <Button Content="取消" Style="{StaticResource DangerButton}" Margin="10,0,0,0" Click="Cancel_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
