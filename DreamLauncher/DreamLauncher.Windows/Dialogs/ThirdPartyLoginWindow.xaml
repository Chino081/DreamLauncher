<Window x:Class="DreamLauncher.Windows.Dialogs.ThirdPartyLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="皮肤站登录"
        Width="460"
        Height="390"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="{StaticResource TextPrimary}">
    <Border Margin="10"
            Padding="20"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource StrokeSoft}"
            BorderThickness="1"
            CornerRadius="20"
            MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Background="Transparent" MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
                <TextBlock Text="皮肤站登录" FontSize="20" FontWeight="Bold" />
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="输入支持 Yggdrasil API 的皮肤站地址和账号密码。密码只用于本次登录，不会保存。"
                       Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,18" />

            <StackPanel Grid.Row="2">
                <TextBlock Text="认证服务器 API Root" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="ApiRootTextBox"
                         Style="{StaticResource LauncherTextBox}"
                         Text="https://littleskin.cn/api/yggdrasil/" />

                <TextBlock Text="账号 / 邮箱" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                <TextBox x:Name="UsernameTextBox" Style="{StaticResource LauncherTextBox}" />

                <TextBlock Text="密码" Style="{StaticResource FieldLabel}" Margin="0,14,0,6" />
                <PasswordBox x:Name="PasswordBox"
                             MinHeight="36"
                             Padding="10,7"
                             Foreground="{StaticResource TextPrimary}"
                             Background="{StaticResource PanelBackgroundAlt}"
                             BorderBrush="{StaticResource StrokeSoft}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" />
                <Button Content="登录" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="Login_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
