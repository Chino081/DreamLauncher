<Window x:Class="DreamLauncher.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dreamtc Tamrac Launcher"
        Icon="Assets/favicon.ico"
        Height="760"
        Width="1180"
        MinHeight="700"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        Foreground="{StaticResource TextPrimary}">
    <Window.Resources>
        <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#182334" Offset="0" />
            <GradientStop Color="#20243D" Offset="0.52" />
            <GradientStop Color="#241D45" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="GlassBrush" Color="#3A4059" Opacity="0.64" />
        <SolidColorBrush x:Key="GlassBrushLight" Color="#555B72" Opacity="0.48" />
        <SolidColorBrush x:Key="PurpleLine" Color="#7D35E8" />

        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GlassBrush}" />
            <Setter Property="BorderBrush" Value="#4B5269" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="TopNavButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#B8B2D8" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="SideNavButton" TargetType="Button" BasedOn="{StaticResource TopNavButton}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Background" Value="#44506A" />
            <Setter Property="BorderBrush" Value="#59647C" />
        </Style>

        <Style x:Key="CloseWindowButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Setter Property="Background" Value="#C2185B" />
            <Setter Property="BorderBrush" Value="#FF6BAF" />
        </Style>

        <Style x:Key="VersionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemRoot"
                                Background="#454B61"
                                BorderBrush="#596176"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#C21869" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#FF5BA7" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#FF65AE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DownloadClientItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ContentItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="GameContentItemTemplate">
            <Border Background="#4A5065"
                    BorderBrush="{Binding StatusBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="82" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding DetailText}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,5,0,0"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="12"
                                   Foreground="{Binding StatusBrush}"
                                   Margin="0,5,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{Binding ActionText}"
                            Style="{StaticResource SecondaryButton}"
                            MinHeight="36"
                            Padding="10,0"
                            Click="ToggleContentItem_Click" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            CornerRadius="22"
            BorderBrush="#2E3850"
            BorderThickness="1"
            Background="{StaticResource ShellBrush}"
            ClipToBounds="True">
        <Grid x:Name="ShellContent"
              SizeChanged="ShellContent_SizeChanged">
            <Ellipse Width="430" Height="430" Fill="#7C4576" Opacity="0.2"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-170,-170,0,0" />
            <Ellipse Width="330" Height="330" Fill="#6E5BB8" Opacity="0.18"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-90,-70,0" />
            <Ellipse Width="300" Height="300" Fill="#9F4C87" Opacity="0.2"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-70,-95" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="76" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Border Width="42" Height="42" Background="{StaticResource Accent}" CornerRadius="21">
                            <TextBlock Text="梦" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Dreamtc Tamrac Launcher" FontSize="20" FontWeight="Bold" />
                            <TextBlock Text="甜酷二次元风 · Minecraft Launcher" FontSize="12" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Button Content="-" Style="{StaticResource WindowButton}" Click="MinimizeButton_Click" Margin="0,0,8,0" />
                        <Button Content="×" Style="{StaticResource CloseWindowButton}" Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Margin="18,18,18,18"
                        Background="#2D334A"
                        BorderBrush="#434A63"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="58" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                            <Button x:Name="LaunchNavButton" Style="{StaticResource TopNavButton}" Content="✦ 启动" Click="LaunchNav_Click" />
                            <Button x:Name="DownloadNavButton" Style="{StaticResource TopNavButton}" Content="⬇ 下载" Click="DownloadNav_Click" Margin="12,0,0,0" />
                            <Button x:Name="ContentNavButton" Style="{StaticResource TopNavButton}" Content="◇ 资源" Click="ContentNav_Click" Margin="12,0,0,0" />
                            <Button x:Name="SettingsNavButton" Style="{StaticResource TopNavButton}" Content="⚙ 设置" Click="SettingsNav_Click" Margin="12,0,0,0" />
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid x:Name="LaunchPage">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="96" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource GlassCard}" Padding="18,14" Margin="0,0,0,14" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="开始游戏" FontSize="24" FontWeight="Bold" LineHeight="30" />
                                        <TextBlock Text="在这里选择版本、查看版本信息，然后直接启动游戏。"
                                                   FontSize="12"
                                                   LineHeight="18"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="300" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource GlassCard}" Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <TextBlock Text="版本列表" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                                                <Border HorizontalAlignment="Right" Background="#43206F" BorderBrush="#8A45FF" BorderThickness="1" CornerRadius="11" Padding="10,4">
                                                    <TextBlock Text="推荐优先" FontSize="12" />
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="1" Background="{StaticResource GlassBrushLight}" BorderBrush="#626A80" BorderThickness="1" CornerRadius="18" Padding="12" Margin="0,16,0,0">
                                                <ListBox ItemsSource="{Binding Clients}"
                                                         SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                                                         ItemContainerStyle="{StaticResource VersionItemStyle}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="{StaticResource TextPrimary}"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" />
                                                                <TextBlock Text="{Binding LoaderText}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,5,0,0" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Column="1" Margin="14,0,1,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="222" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Style="{StaticResource GlassCard}"
                                                BorderBrush="{StaticResource PurpleLine}"
                                                Margin="0,1,0,1"
                                                Padding="17">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="112" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="账号管理" FontSize="18" FontWeight="Bold" LineHeight="24" />
                                                <Border Grid.Row="1" Background="#2B173F" BorderBrush="#7D35E8" BorderThickness="1" CornerRadius="18" Padding="10" Margin="0,12,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="58" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="58" Height="58" Background="{StaticResource Accent}" CornerRadius="17" VerticalAlignment="Center" ClipToBounds="True">
                                                            <Grid>
                                                                <TextBlock Text="{Binding CurrentAccountInitial}" FontSize="25" LineHeight="31" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                <Image Source="{Binding CurrentAccountAvatar}"
                                                                       Stretch="UniformToFill"
                                                                       Visibility="{Binding HasCurrentAccountAvatar, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                                       SnapsToDevicePixels="True">
                                                                    <Image.Clip>
                                                                        <RectangleGeometry Rect="0,0,58,58" RadiusX="17" RadiusY="17" />
                                                                    </Image.Clip>
                                                                </Image>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding CurrentAccountName}" FontSize="17" FontWeight="Bold" LineHeight="22" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding CurrentAccountStatusText}" FontSize="12" LineHeight="17" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="状态：在线" FontSize="12" LineHeight="17" Foreground="{StaticResource Accent}" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <WrapPanel Grid.Row="2" VerticalAlignment="Bottom">
                                                    <Button Content="登录账号" Style="{StaticResource PrimaryButton}" Click="LoginAccountButton_Click" Margin="0,0,10,0" />
                                                    <Button Content="切换账号" Style="{StaticResource SecondaryButton}" Click="SwitchAccountButton_Click" Margin="0" />
                                                </WrapPanel>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock Text="启动面板" FontSize="13" Foreground="#DAB7FF" />
                                                <Button Content="{Binding SelectedClient.PrimaryActionText}" Style="{StaticResource PrimaryButton}" Command="{Binding PrimaryActionCommand}" MinHeight="66" FontSize="20" Margin="0,12,0,0" />
                                                <Button Content="打开版本详情" Style="{StaticResource SecondaryButton}" Click="DownloadNav_Click" Margin="0,14,0,0" HorizontalAlignment="Left" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <Grid x:Name="DownloadPage" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="96" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource GlassCard}" Padding="18,14" Margin="0,0,0,14" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="下载中心" FontSize="24" FontWeight="Bold" LineHeight="30" />
                                        <TextBlock Text="展示可用客户端列表和当前下载进度。"
                                                   FontSize="12"
                                                   LineHeight="18"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="320" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource GlassCard}" Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="客户端列表" FontSize="20" FontWeight="Bold" />
                                            <Border Grid.Row="1" Background="{StaticResource GlassBrushLight}" BorderBrush="#626A80" BorderThickness="1" CornerRadius="18" Padding="12" Margin="0,16,0,0">
                                                <ListBox ItemsSource="{Binding Clients}"
                                                         SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="{StaticResource TextPrimary}"
                                                         ItemContainerStyle="{StaticResource DownloadClientItemStyle}"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#4A5065" BorderBrush="#626A80" BorderThickness="1" CornerRadius="14" Padding="14">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="132" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" />
                                                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                                        <TextBlock Text="{Binding LoaderText}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" />
                                                                    </StackPanel>
                                                                    <Grid Grid.Column="1" Width="132" VerticalAlignment="Center">
                                                                        <Button Content="{Binding DownloadCenterActionText}"
                                                                                Style="{StaticResource PrimaryButton}"
                                                                                Click="ClientActionButton_Click"
                                                                                MinHeight="40"
                                                                                Visibility="{Binding ShowDownloadCenterAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                                        <Border Background="#343A52"
                                                                                BorderBrush="{Binding StatusBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="14"
                                                                                Padding="14,10"
                                                                                Visibility="{Binding ShowDownloadCenterBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                            <TextBlock Text="{Binding DownloadCenterBadgeText}"
                                                                                       Foreground="{Binding StatusBrush}"
                                                                                       FontWeight="Bold"
                                                                                       HorizontalAlignment="Center" />
                                                                        </Border>
                                                                    </Grid>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Column="1" Margin="14,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="180" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Style="{StaticResource GlassCard}">
                                            <StackPanel>
                                                <TextBlock Text="当前下载" FontSize="18" FontWeight="Bold" />
                                                <TextBlock Text="{Binding SelectedClient.Name}" FontSize="14" FontWeight="Bold" Margin="0,14,0,0" />
                                                <TextBlock Text="{Binding SelectedClient.Version, StringFormat=游戏版本：{0}}" Foreground="{StaticResource TextMuted}" Margin="0,18,0,0" />
                                                <TextBlock Text="{Binding SelectedClient.LoaderText, StringFormat=客户端版本：{0}}" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0" />
                                                <TextBlock Text="{Binding SelectedClient.StatusText, StringFormat=状态：{0}}" Foreground="{StaticResource Accent}" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock Text="下载统计" FontSize="18" FontWeight="Bold" />
                                                <Border Background="#464C62" CornerRadius="14" Padding="14" Margin="0,14,0,0">
                                                    <TextBlock Text="{Binding ProgressValue, StringFormat=总进度：{0:0}%}" FontWeight="Bold" />
                                                </Border>
                                                <Border Background="#464C62" CornerRadius="14" Padding="14" Margin="0,12,0,0">
                                                    <TextBlock Text="{Binding OperationText}" TextWrapping="Wrap" />
                                                </Border>
                                                <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Margin="0,14,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <Grid x:Name="ContentPage" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="96" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource GlassCard}" Padding="18,14" Margin="0,0,0,14" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="资源管理" FontSize="24" FontWeight="Bold" LineHeight="30" />
                                        <TextBlock Text="{Binding ContentStatusMessage}"
                                                   FontSize="12"
                                                   LineHeight="18"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource GlassCard}" Padding="14" Margin="0,0,14,0">
                                        <StackPanel>
                                            <TextBlock Text="游戏资源" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="2,0,0,10" />
                                            <Button x:Name="ModSubNavButton"
                                                    Content="{Binding ModsTabText}"
                                                    Style="{StaticResource SideNavButton}"
                                                    Click="ModSubNav_Click"
                                                    HorizontalContentAlignment="Left"
                                                    Margin="0,0,0,8" />
                                            <Button x:Name="ResourcePackSubNavButton"
                                                    Content="{Binding ResourcePacksTabText}"
                                                    Style="{StaticResource SideNavButton}"
                                                    Click="ResourcePackSubNav_Click"
                                                    HorizontalContentAlignment="Left"
                                                    Margin="0,0,0,8" />
                                            <Button x:Name="ShaderPackSubNavButton"
                                                    Content="{Binding ShaderPacksTabText}"
                                                    Style="{StaticResource SideNavButton}"
                                                    Click="ShaderPackSubNav_Click"
                                                    HorizontalContentAlignment="Left" />
                                            <Border Height="1" Background="#596176" Margin="0,18,0,14" />
                                            <TextBlock Text="{Binding ContentGameDirectory}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Style="{StaticResource GlassCard}" Padding="14" Margin="0,0,0,14" MinHeight="74">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="ContentSubTitleTextBlock"
                                                           Text="Mod"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <Button Content="打开文件夹"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Width="118"
                                                            Height="42"
                                                            Padding="0"
                                                            Margin="10,0,0,0"
                                                            Click="OpenContentFolder_Click" />
                                                    <Button Content="从文件安装"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Width="126"
                                                            Height="42"
                                                            Padding="0"
                                                            Margin="10,0,0,0"
                                                            Click="InstallContentFromFile_Click" />
                                                    <Button Content="刷新"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Width="86"
                                                            Height="42"
                                                            Padding="0"
                                                            Margin="10,0,0,0"
                                                            Click="RefreshContent_Click" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Border x:Name="ModContentPanel"
                                                Grid.Row="1"
                                                Style="{StaticResource GlassCard}"
                                                Padding="16"
                                                AllowDrop="True"
                                                PreviewDragOver="ContentDropZone_PreviewDragOver"
                                                Drop="ModDrop_Drop">
                                            <ListBox ItemsSource="{Binding Mods}"
                                                     ItemTemplate="{StaticResource GameContentItemTemplate}"
                                                     ItemContainerStyle="{StaticResource ContentItemStyle}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     AllowDrop="True"
                                                     PreviewDragOver="ContentDropZone_PreviewDragOver"
                                                     Drop="ModDrop_Drop"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                                        </Border>

                                        <Border x:Name="ResourcePackContentPanel"
                                                Grid.Row="1"
                                                Style="{StaticResource GlassCard}"
                                                Padding="16"
                                                Visibility="Collapsed"
                                                AllowDrop="True"
                                                PreviewDragOver="ContentDropZone_PreviewDragOver"
                                                Drop="ResourcePackDrop_Drop">
                                            <ListBox ItemsSource="{Binding ResourcePacks}"
                                                     ItemTemplate="{StaticResource GameContentItemTemplate}"
                                                     ItemContainerStyle="{StaticResource ContentItemStyle}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     AllowDrop="True"
                                                     PreviewDragOver="ContentDropZone_PreviewDragOver"
                                                     Drop="ResourcePackDrop_Drop"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                                        </Border>

                                        <Border x:Name="ShaderPackContentPanel"
                                                Grid.Row="1"
                                                Style="{StaticResource GlassCard}"
                                                Padding="16"
                                                Visibility="Collapsed"
                                                AllowDrop="True"
                                                PreviewDragOver="ContentDropZone_PreviewDragOver"
                                                Drop="ShaderPackDrop_Drop">
                                            <ListBox ItemsSource="{Binding ShaderPacks}"
                                                     ItemTemplate="{StaticResource GameContentItemTemplate}"
                                                     ItemContainerStyle="{StaticResource ContentItemStyle}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     AllowDrop="True"
                                                     PreviewDragOver="ContentDropZone_PreviewDragOver"
                                                     Drop="ShaderPackDrop_Drop"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <Grid x:Name="SettingsPage" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource GlassCard}" Margin="0,0,14,0">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0">
                                        <Border Width="80" Height="80" Background="{StaticResource AccentBlue}" CornerRadius="20" Margin="0,2,0,20">
                                            <TextBlock Text="梦" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="Dreamtc Tamrac Launcher" FontSize="16" FontWeight="Bold" TextAlignment="Center" />
                                        <TextBlock Text="甜酷二次元风" Foreground="{StaticResource TextMuted}" Margin="0,6,0,20" TextAlignment="Center" />
                                        <Border Height="1" Width="190" Background="#586078" Margin="0,0,0,18" />
                                        <TextBlock Text="版本 v0.1.0" Foreground="#8790A8" />
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="78" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Style="{StaticResource GlassCard}" Padding="18,14" Margin="0,0,0,14" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                                        <TextBlock Text="设置" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
                                    </Border>

                                    <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="20">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Java 环境" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" />
                                                <Border Background="#3A4058" CornerRadius="14" Padding="16" Margin="0,10,0,22">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="12" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="8" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="112" />
                                                            <ColumnDefinition Width="96" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.ColumnSpan="3"
                                                                   Text="选择或自动检测 Java 运行环境，用于启动当前选中的 Minecraft 客户端。"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   TextWrapping="Wrap" />

                                                        <ComboBox x:Name="JavaRuntimeComboBox"
                                                                  Grid.Row="2"
                                                                  DisplayMemberPath="DisplayName"
                                                                  SelectedValuePath="JavaPath"
                                                                  MinHeight="36"
                                                                  Padding="10,6"
                                                                  Foreground="{StaticResource TextPrimary}"
                                                                  Background="{StaticResource PanelBackgroundAlt}"
                                                                  BorderBrush="{StaticResource StrokeSoft}"
                                                                  SelectionChanged="JavaRuntimeComboBox_SelectionChanged" />
                                                        <Button x:Name="AutoDetectJavaButton"
                                                                Grid.Row="2"
                                                                Grid.Column="1"
                                                                Content="自动检测"
                                                                Style="{StaticResource PrimaryButton}"
                                                                Margin="12,0,0,0"
                                                                Click="AutoDetectJava_Click" />
                                                        <Button x:Name="AddJavaRuntimeButton"
                                                                Grid.Row="2"
                                                                Grid.Column="2"
                                                                Content="添加"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Margin="12,0,0,0"
                                                                Click="AddJavaRuntime_Click" />

                                                        <TextBlock x:Name="JavaRuntimeStatusTextBlock"
                                                                   Grid.Row="4"
                                                                   Grid.ColumnSpan="3"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>

                                                <TextBlock Text="最大内存" Foreground="#00C28A" FontWeight="Bold" />
                                                <Border Background="#3A4058" CornerRadius="14" Padding="16" Margin="0,10,0,22">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="128" />
                                                            <ColumnDefinition Width="42" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="12" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="8" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.ColumnSpan="3"
                                                                   Text="默认自动使用当前客户端建议内存，也可以选择常用档位或手动填写。"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   TextWrapping="Wrap" />

                                                        <ComboBox x:Name="MemoryPresetComboBox"
                                                                  Grid.Row="2"
                                                                  DisplayMemberPath="DisplayName"
                                                                  MinHeight="36"
                                                                  Padding="10,6"
                                                                  Foreground="{StaticResource TextPrimary}"
                                                                  Background="{StaticResource PanelBackgroundAlt}"
                                                                  BorderBrush="{StaticResource StrokeSoft}"
                                                                  SelectionChanged="MemoryPresetComboBox_SelectionChanged" />
                                                        <TextBox x:Name="CustomMemoryTextBox"
                                                                 Grid.Row="2"
                                                                 Grid.Column="1"
                                                                 Style="{StaticResource LauncherTextBox}"
                                                                 Margin="12,0,0,0" />
                                                        <TextBlock Grid.Row="2"
                                                                   Grid.Column="2"
                                                                   Text="MB"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock x:Name="MemoryStatusTextBlock"
                                                                   Grid.Row="4"
                                                                   Grid.ColumnSpan="3"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Border>

                                                <TextBlock Text="下载" Foreground="{StaticResource Accent}" FontWeight="Bold" />
                                                <Border Background="#3A4058" CornerRadius="14" Padding="16" Margin="0,10,0,22">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="12" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="失败重试次数" VerticalAlignment="Center" />
                                                        <TextBox x:Name="MainMaxRetryCountTextBox" Grid.Column="1" Style="{StaticResource LauncherTextBox}" />
                                                        <TextBlock Grid.Row="2" Text="下载限速 KB/s" VerticalAlignment="Center" />
                                                        <TextBox x:Name="MainSpeedLimitTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource LauncherTextBox}" />
                                                    </Grid>
                                                </Border>

                                                <TextBlock Text="文件校验工具" Foreground="#00C28A" FontWeight="Bold" />
                                                <Border Background="#3A4058" CornerRadius="14" Padding="16" Margin="0,10,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="86" />
                                                            <ColumnDefinition Width="86" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="12" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="12" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="12" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="12" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Text="本地文件" VerticalAlignment="Center" />
                                                        <TextBox x:Name="HashToolPathTextBox" Grid.Column="1" Style="{StaticResource LauncherTextBox}" />
                                                        <Button Grid.Column="2" Content="选择" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="ChooseHashFile_Click" />
                                                        <Button Grid.Column="3" Content="计算" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="CalculateHash_Click" />

                                                        <TextBlock Grid.Row="2" Text="SHA256" VerticalAlignment="Center" />
                                                        <TextBox x:Name="HashToolSha256TextBox"
                                                                 Grid.Row="2"
                                                                 Grid.Column="1"
                                                                 Grid.ColumnSpan="3"
                                                                 Style="{StaticResource LauncherTextBox}"
                                                                 IsReadOnly="True" />

                                                        <TextBlock Grid.Row="4" Text="Size 字节" VerticalAlignment="Center" />
                                                        <TextBox x:Name="HashToolSizeTextBox"
                                                                 Grid.Row="4"
                                                                 Grid.Column="1"
                                                                 Grid.ColumnSpan="3"
                                                                 Style="{StaticResource LauncherTextBox}"
                                                                 IsReadOnly="True" />

                                                        <TextBlock Grid.Row="6" Text="JSON 片段" VerticalAlignment="Top" Margin="0,8,0,0" />
                                                        <TextBox x:Name="HashToolJsonTextBox"
                                                                 Grid.Row="6"
                                                                 Grid.Column="1"
                                                                 Grid.ColumnSpan="3"
                                                                 Height="76"
                                                                 Style="{StaticResource LauncherTextBox}"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 TextWrapping="Wrap"
                                                                 VerticalScrollBarVisibility="Auto" />

                                                        <Button Grid.Row="8"
                                                                Grid.Column="3"
                                                                Content="复制结果"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Margin="10,0,0,0"
                                                                Click="CopyHashResult_Click" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                                    <Button Content="重新读取" Style="{StaticResource SecondaryButton}" Click="ReloadInlineSettings_Click" />
                                                    <Button Content="保存设置" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="SaveInlineSettings_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
