<Window x:Class="DreamLauncher.Windows.OfflineAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="离线测试账号"
        Width="420"
        Height="260"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="{StaticResource TextPrimary}">
    <Border Margin="10"
            Padding="20"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource StrokeSoft}"
            BorderThickness="1"
            CornerRadius="20"
            MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Background="Transparent" MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
                <TextBlock Text="创建离线测试账号" FontSize="20" FontWeight="Bold" />
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="用于开发测试或离线服务器，不等同于正版登录。"
                       Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,18" />

            <StackPanel Grid.Row="2">
                <TextBlock Text="玩家名" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="PlayerNameTextBox"
                         Style="{StaticResource LauncherTextBox}"
                         Text="Player"
                         MaxLength="16" />
                <TextBlock Text="3-16 位英文、数字或下划线"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="12"
                           Margin="0,8,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" />
                <Button Content="创建" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="Create_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
