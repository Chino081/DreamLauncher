<Window x:Class="DreamLauncher.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:accounts="clr-namespace:DreamLauncher.Models.Accounts;assembly=DreamLauncher.Models"
        Title="设置"
        Width="760"
        Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="{StaticResource TextPrimary}">
    <Border Margin="10"
            Padding="22"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource StrokeSoft}"
            BorderThickness="1"
            CornerRadius="20"
            MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Background="Transparent" MouseLeftButtonDown="Dialog_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock Text="设置" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="远程源、Microsoft 登录、账号与运行时配置" Margin="0,6,0,18" Foreground="{StaticResource TextMuted}" />
                </StackPanel>
            </Grid>

        <TabControl Grid.Row="1" Style="{StaticResource LauncherTabControl}">
            <TabItem Header="远程源">
                <Grid Margin="2,18,2,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="clients.json" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="ClientsManifestUrlTextBox" Style="{StaticResource LauncherTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock Text="java-runtimes.json" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="JavaRuntimesUrlTextBox" Style="{StaticResource LauncherTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,14,0,0">
                        <TextBlock Text="announcement.json" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="AnnouncementUrlTextBox" Style="{StaticResource LauncherTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,18,0,0">
                        <TextBlock Text="本地数据目录" Style="{StaticResource FieldLabel}" />
                        <TextBlock x:Name="RootPathTextBlock" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Microsoft">
                <Grid Margin="2,18,2,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="OAuth Client ID" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="MicrosoftClientIdTextBox" Style="{StaticResource LauncherTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock Text="authlib-injector.jar 路径" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="AuthlibInjectorJarPathTextBox" Style="{StaticResource LauncherTextBox}" />
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="0,18,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="账号管理" FontSize="16" FontWeight="SemiBold" />

                            <ListBox x:Name="AccountsListBox"
                                     Grid.Row="1"
                                     Margin="0,12,0,12"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextPrimary}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type accounts:AccountMetadata}">
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding PlayerName}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Uuid}" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{StaticResource TextMuted}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="设为默认" Style="{StaticResource SecondaryButton}" Click="SetDefaultAccount_Click" />
                                <Button Content="删除账号" Style="{StaticResource DangerButton}" Margin="10,0,0,0" Click="DeleteAccount_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="下载">
                <Grid Margin="2,18,2,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="失败重试次数" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="MaxRetryCountTextBox" Style="{StaticResource LauncherTextBox}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock Text="下载限速 KB/s（留空表示不限速，后续版本启用）" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="SpeedLimitTextBox" Style="{StaticResource LauncherTextBox}" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" />
            <Button Content="保存" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="Save_Click" />
        </StackPanel>
        </Grid>
    </Border>
</Window>
